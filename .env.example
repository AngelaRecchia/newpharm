# Storyblok Configuration
# Get these from: https://app.storyblok.com

# CDN Token (Public Token from Storyblok Settings > Access Tokens)
NEXT_PUBLIC_STORYBLOK_ACCESS_TOKEN=your_cdn_token_here

# Space ID (from Storyblok Settings > General)
NEXT_PUBLIC_STORYBLOK_SPACE_ID=your_space_id_here

# Management Token (from https://app.storyblok.com/#/me/account)
# Required for fetching locales and generating types
STORYBLOK_MANAGEMENT_TOKEN=your_management_token_here
